      "roundness": null,
      "seed": 768794287,
      "version": 125,
      "versionNonce": 1851869295,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1784373761406,
      "link": null,
      "locked": false,
      "text": "That's why Flutter Release has no VM Because we know ABI (Application Binary Interface)",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "That's why Flutter Release has no VM Because we know ABI (Application Binary Interface)",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
