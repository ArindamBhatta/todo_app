      "type": "text",
      "x": 198.2374499736087,
      "y": -58.12031663189043,
      "width": 1620.540771484375,
      "height": 45,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
